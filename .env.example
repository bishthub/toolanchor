# ── Site ─────────────────────────────────────────────────────────────────
# Your real domain — drives canonical URLs, OG tags, sitemap, JSON-LD.
# IMPORTANT: set this in production so canonicals/OG/sitemap resolve to the
# live domain (falls back to https://toolanchor.com if unset).
NEXT_PUBLIC_SITE_URL=https://toolanchor.com

# ── AI Content Detector ("Deep AI analysis") ────────────────────────────
# All optional. The detector ALWAYS works with free in-browser stylometry.
# Add any of these to enable the blended LLM-judge "deep analysis" signal.
# Each provider degrades gracefully if its key is missing or the API fails.

# Google Gemini — generous free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (fast, free Llama) — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# HuggingFace AI-text classifier (free tier) — https://huggingface.co/settings/tokens
HF_API_KEY=
HF_MODEL=Hello-SimpleAI/chatgpt-detector-roberta

# Generous free deep-analysis checks per visitor IP per day.
AI_DETECT_DAILY_FREE=50

# ── Contact ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CONTACT_EMAIL=hello@toolanchor.com

# ── Analytics (privacy-friendly, cookieless — optional) ─────────────────
# Set to your domain to enable Plausible. Leave blank for zero tracking.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Optional: self-hosted Plausible script URL.
NEXT_PUBLIC_PLAUSIBLE_SRC=

# ── Search engine verification (optional) ───────────────────────────────
# Google Search Console → the content of the meta verification tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools → the msvalidate.01 value.
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ── IndexNow (instant Bing/Yandex indexing — optional) ──────────────────
# Any random string (e.g. a UUID). Served at /indexnow-key.txt and used by
# POST /api/indexnow?key=... to submit URLs.
INDEXNOW_KEY=
